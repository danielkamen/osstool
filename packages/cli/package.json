{
  "name": "@contrib-provenance/cli",
  "version": "0.1.2",
  "description": "CLI for Contribution Provenance",
  "bin": {
    "provenance": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "postinstall": "node -e \"try{require('./dist/postinstall.js')}catch(e){process.stderr.write('contrib-provenance: '+((e&&e.message)||'setup skipped')+'\\n')}\"",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contrib-provenance/core": "*",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "yargs": "^17.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/yargs": "^17.0.32",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
